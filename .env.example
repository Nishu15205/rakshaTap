# Database (Required for Vercel)
# Use Vercel Postgres, Supabase, Neon, or any PostgreSQL database
DATABASE_URL="postgresql://user:password@host:5432/rakshatap?sslmode=require"

# NextAuth (Required for production)
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="https://your-app-name.vercel.app"

# Optional: Telegram Bot for notifications
TELEGRAM_BOT_TOKEN=""

# Optional: Twilio for SMS (if using real SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Optional: Resend/SendGrid for emails
EMAIL_SERVICE_URL=""
EMAIL_API_KEY=""
